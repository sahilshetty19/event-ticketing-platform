# ---------------------------------------------------------------------------
# Copy this file to `.env` and adjust values for your machine.
# `.env` is gitignored and holds the real secrets used by docker compose.
# ---------------------------------------------------------------------------

# SQL Server (one shared instance; each service uses its own database).
# Must satisfy the SQL Server strong-password policy.
MSSQL_SA_PASSWORD=Str0ng_Passw0rd!
SQL_PORT=1433

# Redis
REDIS_PORT=6379

# RabbitMQ (a dedicated user — the default 'guest' cannot connect across the Docker network)
RABBITMQ_USER=eventuser
RABBITMQ_PASSWORD=Event_Passw0rd!
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Host ports mapped to each service.
GATEWAY_HTTP_PORT=8080
CATALOG_HTTP_PORT=5001
BOOKING_HTTP_PORT=5002
NOTIFICATION_HTTP_PORT=5003
PAYMENT_HTTP_PORT=5004

# ASP.NET Core environment (Development enables Swagger UI).
ASPNETCORE_ENVIRONMENT=Development
